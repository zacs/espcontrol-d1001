# Copy to `.env` and fill in. Do NOT commit the real .env (it holds a token).

# Repo the runner registers against.
REPO_URL=https://github.com/zacs/espcontrol-d1001

# GitHub Personal Access Token used ONLY to self-register the runner.
#   classic:      scope `repo`
#   fine-grained: this repo, Administration = Read/Write, Actions = Read/Write
ACCESS_TOKEN=ghp_replace_me

# Friendly runner name shown in the repo's runner list.
RUNNER_NAME=d1001-hil

# Labels the HIL workflow targets. Keep `d1001-hil`.
LABELS=self-hosted,d1001-hil,esp32p4

# Serial device node of the attached D1001 on the host (e.g. /dev/ttyUSB0,
# /dev/ttyACM0, or a stable /dev/serial/by-id/... path).
HIL_SERIAL_PORT=/dev/ttyUSB0

# Numeric GID that owns the serial device on the host. Find it with:
#   getent group dialout   (Debian/Ubuntu)   or   ls -l /dev/ttyUSB0
SERIAL_GID=20
