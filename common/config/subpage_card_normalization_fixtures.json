    "expected": { "entity": "", "label": "My Lights", "icon": "Star", "icon_on": "Auto", "sensor": "indicator", "unit": "", "type": "subpage", "precision": "", "options": "subpage_kind=lights" }
  },
  {
    "name": "invalid preset remains generic and drops the preset option",
    "input": ";Rooms;View Grid;Custom;sensor.room;C;subpage;1;subpage_kind=invalid,large_numbers=off,unknown=1",
    "expected": { "entity": "", "label": "Rooms", "icon": "View Grid", "icon_on": "Custom", "sensor": "sensor.room", "unit": "C", "type": "subpage", "precision": "1", "options": "large_numbers=off" }
  }
